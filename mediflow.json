              "raw": "{\n  \"full_name\": \"Nurse Amina Hassan\",\n  \"email\": \"amina.hassan@hospital.org\",\n  \"phone_number\": \"+254723456789\",\n  \"role\": \"nurse\",\n  \"password\": \"TempPass@2026!\"\n}",
